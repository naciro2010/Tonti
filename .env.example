# ============================================
# TONTI Frontend - Variables d'environnement
# ============================================

# URL de l'API backend
VITE_API_URL=http://localhost:8080/api/v1

# Clé publique Stripe (pk_test_... ou pk_live_...)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Apple Pay Merchant ID
VITE_APPLE_PAY_MERCHANT_ID=merchant.com.tonti.app

# Google Pay Environment (TEST ou PRODUCTION)
VITE_GOOGLE_PAY_ENVIRONMENT=TEST

# Analytics (optionnel)
VITE_PLAUSIBLE_DOMAIN=tonti.app
